---
import Header from '../components/Header.astro';
import NavOverlay from '../components/NavOverlay.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Manifesto from '../components/Manifesto.astro';
import Partners from '../components/Partners.astro';
import Latest from '../components/Latest.astro';
import Connect from '../components/Connect.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PB&J — Surgical Talent Agency</title>
  <meta name="description" content="PB&J is an intentionally small talent agency representing elite surgeons — connecting clinical mastery with speaking, advisory, and brand partnerships." />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://madewithpbj.github.io/pbjwebsite/" />

  <!-- Open Graph -->
  <meta property="og:title" content="PB&J — Surgical Talent Agency" />
  <meta property="og:description" content="Intentionally small. Impossibly selective." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://madewithpbj.github.io/pbjwebsite/" />
  <meta property="og:image" content="https://madewithpbj.github.io/pbjwebsite/assets/PBJ-wordmark.svg" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="PB&J — Surgical Talent Agency" />
  <meta name="twitter:description" content="Intentionally small. Impossibly selective." />
  <meta name="twitter:image" content="https://madewithpbj.github.io/pbjwebsite/assets/PBJ-wordmark.svg" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600&family=Montserrat:wght@300;400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <style is:global lang="scss">
    @import '../styles/global.scss';
  </style>
</head>

<body>
  <Header />
  <NavOverlay />
  <Hero />

  <!-- Landing logo: position:fixed, animated by GSAP from center → header -->
  <img
    class="logo-landing"
    src={`${import.meta.env.BASE_URL}/assets/PBJ-wordmark.svg`}
    alt="PB&J Agency"
    width="280"
  />

  <main class="page-main">
    <Manifesto />
    <About />
    <Partners />
    <Latest />
    <Connect />
  </main>

  <Footer />

  <script>
    import '../scripts/main.js';
  </script>
</body>
</html>
