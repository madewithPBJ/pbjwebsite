---
---

<section id="latest" class="latest">
  <div class="latest__inner wrap">
    <p class="eyebrow latest__eyebrow">Latest</p>

    <div class="latest__grid">

      <article class="latest-card js-fade-up">
        <div class="latest-card__img">
          <img
            src={`${import.meta.env.BASE_URL}/assets/latest-signing.jpg`}
            alt="PBJ welcomes new surgeon to roster"
          />
        </div>
        <div class="latest-card__body">
          <p class="latest-card__label">New Signing</p>
          <h3 class="latest-card__headline">PBJ Welcomes Dr. [Name], Neurosurgeon</h3>
        </div>
      </article>

      <article class="latest-card js-fade-up">
        <div class="latest-card__img">
          <img
            src={`${import.meta.env.BASE_URL}/assets/latest-partnership.jpg`}
            alt="New advisory partnership announcement"
          />
        </div>
        <div class="latest-card__body">
          <p class="latest-card__label">Partnership</p>
          <h3 class="latest-card__headline">Dr. [Name] &times; [Brand]: Advisory Role Announced</h3>
        </div>
      </article>

      <article class="latest-card js-fade-up">
        <div class="latest-card__img">
          <img
            src={`${import.meta.env.BASE_URL}/assets/latest-speaking.jpg`}
            alt="Surgeon keynote speaking engagement"
          />
        </div>
        <div class="latest-card__body">
          <p class="latest-card__label">Speaking</p>
          <h3 class="latest-card__headline">Dr. [Name] Headlines [Conference] Keynote</h3>
        </div>
      </article>

      <article class="latest-card js-fade-up">
        <div class="latest-card__img">
          <img
            src={`${import.meta.env.BASE_URL}/assets/latest-press.jpg`}
            alt="PBJ Agency press feature"
          />
        </div>
        <div class="latest-card__body">
          <p class="latest-card__label">In the Press</p>
          <h3 class="latest-card__headline">PBJ Featured in [Publication]</h3>
        </div>
      </article>

    </div>
  </div>
</section>

<style lang="scss">
  .latest {
    position: relative;
    z-index: 2;
    background: var(--burgundy-deep);
    padding: 120px 0;

    @media (max-width: 768px) {
      padding: 80px 0;
    }
  }

  .latest__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .latest__eyebrow {
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 56px;
  }

  .latest__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px 40px;

    @media (max-width: 768px) {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  .latest-card {
    display: flex;
    flex-direction: column;
    gap: 20px;

    &__img {
      overflow: hidden;
      aspect-ratio: 16 / 9;
      background: rgba(255, 255, 255, 0.06);

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        display: block;
        transition: transform 400ms ease;
      }
    }

    &:hover &__img img {
      transform: scale(1.03);
    }

    &__body {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    &__label {
      font-family: var(--font-sans);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--gold-light);
    }

    &__headline {
      font-family: var(--font-serif);
      font-size: clamp(20px, 2.2vw, 26px);
      font-weight: 400;
      color: rgba(255, 255, 255, 0.85);
      line-height: 1.25;
      letter-spacing: -0.2px;
    }
  }
</style>
