---
---

<section id="latest" class="latest">
  <div class="latest__inner">
    <p class="eyebrow latest__eyebrow wrap">Latest</p>

    <div class="latest__grid">

      <article class="latest-card latest-card--featured js-fade-up">
        <div class="latest-card__img">
          <img
            src={`${import.meta.env.BASE_URL}/assets/schoeff-headshot.png`}
            alt="Dr. Jonathan Schoeff, Spine Access Surgeon"
            style="object-position: top center;"
          />
        </div>
        <div class="latest-card__body">
          <p class="latest-card__label">New Signing</p>
          <h3 class="latest-card__headline">PB&amp;J Welcomes Dr. Jonathan Schoeff, Spine Access Surgeon &amp; Longevity Expert</h3>
        </div>
      </article>

      <article class="latest-card js-fade-up">
        <div class="latest-card__img">
          <img
            src={`${import.meta.env.BASE_URL}/assets/transparent-labs.png`}
            alt="Dr. Schoeff partners with Transparent Labs"
          />
        </div>
        <div class="latest-card__body">
          <p class="latest-card__label">Partnership</p>
          <h3 class="latest-card__headline">Dr. Schoeff &times; Transparent Labs</h3>
        </div>
      </article>

      <article class="latest-card js-fade-up">
        <div class="latest-card__img">
          <img
            src={`${import.meta.env.BASE_URL}/assets/signos.png`}
            alt="Dr. Schoeff partners with Signos"
          />
        </div>
        <div class="latest-card__body">
          <p class="latest-card__label">Partnership</p>
          <h3 class="latest-card__headline">Dr. Schoeff &times; Signos</h3>
        </div>
      </article>

      <article class="latest-card js-fade-up">
        <div class="latest-card__img">
          <img
            src={`${import.meta.env.BASE_URL}/assets/plastic-detox.png`}
            alt="Dr. Schoeff partners with OPS and Million Marker for Netflix microplastics launch"
          />
        </div>
        <div class="latest-card__body">
          <p class="latest-card__label">Partnership</p>
          <h3 class="latest-card__headline">Dr. Schoeff &times; OPS &amp; Million Marker — Supporting the Netflix Microplastics Launch</h3>
        </div>
      </article>

    </div>
  </div>
</section>

<style lang="scss">
  .latest {
    position: relative;
    z-index: 2;
    background: var(--burgundy-deep);
    padding: 120px 0;

    @media (max-width: 768px) {
      padding: 80px 0;
    }
  }

  .latest__inner {
    max-width: 100%;
  }

  .latest__eyebrow {
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
  }

  .latest__grid {
    padding-left: 24px;
    padding-right: 24px;

    @media (min-width: 1248px) {
      padding-left: calc((100% - 1200px) / 2);
      padding-right: calc((100% - 1200px) / 2);
    }
  }

  .latest__eyebrow {
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 40px;
  }

  .latest__grid {
    display: flex;
    overflow-x: auto;
    gap: 24px;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;

    &::-webkit-scrollbar {
      display: none;
    }
  }

  .latest-card {
    flex: 0 0 260px;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: 16px;

    &__img {
      overflow: hidden;
      aspect-ratio: 3 / 4;
      background: rgba(255, 255, 255, 0.06);

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        display: block;
        transition: transform 400ms ease;
      }
    }

    &:hover &__img img {
      transform: scale(1.03);
    }

    &__body {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    &__label {
      font-family: var(--font-sans);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--gold-light);
    }

    &__headline {
      font-family: var(--font-serif);
      font-size: 18px;
      font-weight: 400;
      color: rgba(255, 255, 255, 0.85);
      line-height: 1.25;
      letter-spacing: -0.2px;
    }
  }

  .latest-card--featured {
    flex: 0 0 340px;

    .latest-card__img {
      aspect-ratio: 3 / 4;
    }

    .latest-card__headline {
      font-size: 22px;
    }
  }
</style>
