---
---

<div id="nav-backdrop" class="nav-backdrop" aria-hidden="true"></div>
<div id="nav-overlay" class="nav-overlay" role="dialog" aria-modal="true" aria-label="Navigation">

  <!-- ─── Main nav panel ─────────────────────────────────── -->
  <div class="nav-inner wrap">

    <div class="nav-top">
      <a href={`${import.meta.env.BASE_URL}/`} aria-label="PB&J Agency — Home">
        <img src={`${import.meta.env.BASE_URL}/assets/PBJ-wordmark.svg`} alt="PB&J Agency" class="nav-logo" width="120" />
      </a>
      <button id="nav-close" class="nav-close" aria-label="Close navigation">
        <span>CLOSE</span>
      </button>
    </div>

    <nav class="nav-links" aria-label="Primary">
      <a href={`${import.meta.env.BASE_URL}/our-process/`} class="nav-link">Our Process</a>
      <a href={`${import.meta.env.BASE_URL}/who-we-are/`}  class="nav-link">Who We Are</a>
      <a href={`${import.meta.env.BASE_URL}/#connect`}     class="nav-link">Contact</a>
    </nav>

    <div class="nav-ctas">
      <button class="nav-cta" data-form-trigger="form-surgeon">Apply to Our Roster</button>
      <button class="nav-cta" data-form-trigger="form-partners">Work With Our Talent</button>
      <button class="nav-cta" data-form-trigger="form-team">Join Our Team</button>
    </div>

    <div class="nav-footer">
      <a href="mailto:admin@madewithpbj.com" class="nav-footer__email">
        admin@madewithpbj.com
      </a>

      <div class="nav-footer__social">
        <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="nav-footer__social-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
        <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="nav-footer__social-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
      </div>

      <span class="nav-footer__copy">Denver, CO</span>
    </div>

  </div>

  <!-- ─── Form Panel: For Surgeons ──────────────────────── -->
  <div id="form-surgeon" class="form-panel" data-lenis-prevent>
    <div class="form-panel__inner wrap">
      <div class="form-panel__header">
        <h2 class="form-panel__title">Apply to Our Roster</h2>
        <button class="form-panel-close" aria-label="Back to navigation">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Back
        </button>
      </div>

      <form class="form-panel__form" action="https://formspree.io/f/xrerlzwq" method="POST">
        <input type="hidden" name="_subject" value="Surgeon Application — PB&J Agency" />

        <div class="form-group">
          <label for="surgeon-name">Full Name</label>
          <input type="text" id="surgeon-name" name="name" required autocomplete="name" />
        </div>
        <div class="form-group">
          <label for="surgeon-email">Email</label>
          <input type="email" id="surgeon-email" name="email" required autocomplete="email" />
        </div>
        <div class="form-group">
          <label for="surgeon-specialty">Specialty</label>
          <input type="text" id="surgeon-specialty" name="specialty" required />
        </div>
        <div class="form-group">
          <label for="surgeon-institution">Current Institution</label>
          <input type="text" id="surgeon-institution" name="institution" required />
        </div>
        <div class="form-group">
          <label for="surgeon-linkedin">LinkedIn URL</label>
          <input type="url" id="surgeon-linkedin" name="linkedin" placeholder="https://linkedin.com/in/…" />
        </div>
        <div class="form-group">
          <label for="surgeon-bio">Brief Bio / Why PB&amp;J</label>
          <textarea id="surgeon-bio" name="bio" rows="4" required></textarea>
        </div>

        <button type="submit" class="btn btn-outline-gold form-submit">Submit Application</button>
      </form>
    </div>
  </div>

  <!-- ─── Form Panel: For Partners ──────────────────────── -->
  <div id="form-partners" class="form-panel" data-lenis-prevent>
    <div class="form-panel__inner wrap">
      <div class="form-panel__header">
        <h2 class="form-panel__title">Work With Our Talent</h2>
        <button class="form-panel-close" aria-label="Back to navigation">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Back
        </button>
      </div>

      <form class="form-panel__form" action="https://formspree.io/f/mjgjobqe" method="POST">
        <input type="hidden" name="_subject" value="Partner Inquiry — PB&J Agency" />

        <div class="form-group">
          <label for="partner-name">Full Name</label>
          <input type="text" id="partner-name" name="name" required autocomplete="name" />
        </div>
        <div class="form-group">
          <label for="partner-email">Email</label>
          <input type="email" id="partner-email" name="email" required autocomplete="email" />
        </div>
        <div class="form-group">
          <label for="partner-org">Organization / Brand Name</label>
          <input type="text" id="partner-org" name="organization" required />
        </div>
        <div class="form-group">
          <label for="partner-type">Nature of Inquiry</label>
          <select id="partner-type" name="inquiry_type" required>
            <option value="" disabled selected>Select one</option>
            <option value="speaking">Speaking</option>
            <option value="brand-partnership">Brand Partnership</option>
            <option value="advisory">Advisory</option>
            <option value="media">Media</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div class="form-group">
          <label for="partner-message">Message</label>
          <textarea id="partner-message" name="message" rows="4" required></textarea>
        </div>

        <button type="submit" class="btn btn-outline-gold form-submit">Send Inquiry</button>
      </form>
    </div>
  </div>

  <!-- ─── Form Panel: Join Our Team ─────────────────────── -->
  <div id="form-team" class="form-panel" data-lenis-prevent>
    <div class="form-panel__inner wrap">
      <div class="form-panel__header">
        <h2 class="form-panel__title">Join Our Team</h2>
        <button class="form-panel-close" aria-label="Back to navigation">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Back
        </button>
      </div>

      <form class="form-panel__form" action="https://formspree.io/f/myklpgqv" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="_subject" value="Team Application — PB&J Agency" />

        <div class="form-group">
          <label for="team-name">Full Name</label>
          <input type="text" id="team-name" name="name" required autocomplete="name" />
        </div>
        <div class="form-group">
          <label for="team-email">Email</label>
          <input type="email" id="team-email" name="email" required autocomplete="email" />
        </div>
        <div class="form-group">
          <label for="team-role">Role of Interest</label>
          <input type="text" id="team-role" name="role" required placeholder="e.g. Talent Manager, Marketing" />
        </div>
        <div class="form-group">
          <label for="team-resume">Resume / CV</label>
          <input type="file" id="team-resume" name="resume" accept=".pdf,.doc,.docx" />
        </div>
        <div class="form-group">
          <label for="team-message">Brief Message</label>
          <textarea id="team-message" name="message" rows="4" required></textarea>
        </div>

        <button type="submit" class="btn btn-outline-gold form-submit">Submit</button>
      </form>
    </div>
  </div>

</div>

<style lang="scss">
  .nav-backdrop {
    position: fixed;
    inset: 0;
    z-index: 149;
    background: rgba(10, 4, 8, 0.55);
    pointer-events: none;
    opacity: 0;
    cursor: pointer;
  }

  .nav-overlay {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(56vw, 820px);
    min-width: 400px;
    z-index: 150;
    background: var(--burgundy-deep);
    display: flex;
    flex-direction: column;
    overflow: hidden;

    @media (max-width: 768px) {
      width: 100%;
      min-width: unset;
    }
  }

  // ─── Main nav inner ───────────────────────────────────
  .nav-inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding-top: 22px;
    padding-bottom: 40px;
    overflow-y: auto;
    max-width: 100%;
  }

  .nav-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0;
    margin-bottom: 0;
  }

  .nav-logo {
    width: 100px;
    opacity: 0.9;
  }

  .nav-close {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    transition: color 200ms ease;

    &:hover {
      color: var(--white);
    }
  }

  // ─── Nav links ────────────────────────────────────────
  .nav-links {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 80px;
    margin-bottom: 48px;
  }

  .nav-link {
    font-family: var(--font-serif);
    font-size: clamp(36px, 5.5vw, 52px);
    font-weight: 400;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
    line-height: 0.9;
    padding: 14px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transition: color 200ms ease, padding-left 200ms ease;

    &:first-child {
      border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    &:hover {
      color: var(--white);
      padding-left: 8px;
    }
  }

  // ─── CTA links ────────────────────────────────────────
  .nav-ctas {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: auto;
  }

  .nav-cta {
    font-family: var(--font-serif);
    font-size: clamp(18px, 2.5vw, 24px);
    font-weight: 300;
    font-style: italic;
    color: rgba(255, 255, 255, 0.45);
    text-align: left;
    padding: 6px 0;
    transition: color 200ms ease;
    cursor: pointer;

    &:hover {
      color: var(--gold-light);
    }
  }

  // ─── Nav footer ──────────────────────────────────────
  .nav-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-top: 32px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    flex-wrap: wrap;
    margin-top: 48px;

    &__email {
      font-family: var(--font-sans);
      font-size: var(--text-xs);
      color: rgba(255, 255, 255, 0.4);
      letter-spacing: 1px;
      transition: color 200ms ease;

      &:hover { color: var(--white); }
    }

    &__social {
      display: flex;
      gap: 16px;
    }

    &__social-link {
      color: rgba(255, 255, 255, 0.35);
      transition: color 200ms ease;

      &:hover { color: var(--white); }
    }

    &__copy {
      font-family: var(--font-sans);
      font-size: var(--text-xs);
      color: rgba(255, 255, 255, 0.25);
      letter-spacing: 2px;
      text-transform: uppercase;
    }
  }

  // ─── Form panels ─────────────────────────────────────
  .form-panel {
    position: absolute;
    inset: 0;
    z-index: 10;
    background: var(--plum-deep);
    overflow-y: auto;
    // Initial state set by GSAP in main.js

    &__inner {
      padding-top: 32px;
      padding-bottom: 64px;
      min-height: 100%;
      max-width: 680px;
    }

    &__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 56px;
    }

    &__title {
      font-family: var(--font-serif);
      font-size: clamp(24px, 3.5vw, 36px);
      font-weight: 300;
      font-style: italic;
      color: var(--white);
    }
  }

  .form-panel-close {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    transition: color 200ms ease;

    &:hover { color: var(--white); }

    svg { flex-shrink: 0; }
  }

  // ─── Form elements ────────────────────────────────────
  .form-panel__form {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 10px;

    label {
      font-family: var(--font-sans);
      font-size: var(--text-xs);
      font-weight: 600;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.4);
    }

    input,
    textarea,
    select {
      font-family: var(--font-sans);
      font-size: var(--text-base);
      color: var(--white);
      background: transparent;
      border: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.2);
      padding: 10px 0;
      outline: none;
      transition: border-color 200ms ease;
      width: 100%;

      &::placeholder {
        color: rgba(255, 255, 255, 0.2);
      }

      &:focus {
        border-color: var(--gold-light);
      }
    }

    select {
      appearance: none;
      cursor: pointer;

      option {
        background: var(--plum-deep);
        color: var(--white);
      }
    }

    textarea {
      resize: vertical;
      min-height: 100px;
    }

    input[type="file"] {
      color: rgba(255, 255, 255, 0.5);
      font-size: var(--text-sm);
      cursor: pointer;
    }
  }

  .form-submit {
    align-self: flex-start;
    margin-top: 8px;
  }

  .form-success {
    display: none;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    padding-top: 48px;

    &__icon {
      width: 40px;
      height: 40px;
      color: var(--gold-light);
    }

    &__title {
      font-family: var(--font-serif);
      font-size: clamp(24px, 3vw, 36px);
      font-weight: 300;
      font-style: italic;
      color: var(--white);
    }

    &__body {
      font-family: var(--font-sans);
      font-size: var(--text-base);
      color: rgba(255, 255, 255, 0.55);
      line-height: 1.7;
    }
  }

  .form-error {
    display: none;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: #e07070;
    margin-top: -16px;
  }
</style>

<script>
  document.querySelectorAll<HTMLFormElement>('.form-panel__form').forEach((form) => {
    const panel = form.closest('.form-panel') as HTMLElement;
    const submitBtn = form.querySelector<HTMLButtonElement>('.form-submit');
    let errorEl = form.querySelector<HTMLElement>('.form-error');

    if (!errorEl) {
      errorEl = document.createElement('p');
      errorEl.className = 'form-error';
      errorEl.textContent = 'Something went wrong. Please try again or email us directly.';
      submitBtn?.insertAdjacentElement('afterend', errorEl);
    }

    // Build success state once per panel
    const successHtml = `
      <div class="form-success">
        <svg class="form-success__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 6L9 17l-5-5"/>
        </svg>
        <p class="form-success__title">We'll be in touch.</p>
        <p class="form-success__body">Your submission was received. We review every inquiry personally and will respond within a few business days.</p>
      </div>
    `;
    form.insertAdjacentHTML('afterend', successHtml);
    const successEl = panel?.querySelector<HTMLElement>('.form-success');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!submitBtn) return;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';
      if (errorEl) errorEl.style.display = 'none';

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          form.style.display = 'none';
          if (successEl) successEl.style.display = 'flex';
        } else {
          throw new Error('server');
        }
      } catch {
        submitBtn.disabled = false;
        submitBtn.textContent = submitBtn.dataset.label ?? 'Submit';
        if (errorEl) errorEl.style.display = 'block';
      }
    });

    // Stash original label for error recovery
    if (submitBtn) submitBtn.dataset.label = submitBtn.textContent ?? '';
  });
</script>
