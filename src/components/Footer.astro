---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner wrap">

    <div class="footer-info">
      <div class="footer-left">
        <a href="mailto:hello@pbandjagency.com" class="footer-email">
          hello@pbandjagency.com
        </a>
        <span class="footer-location">Denver, CO</span>
      </div>

      <div class="footer-social">
        <a
          href="https://instagram.com"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-social__link"
          aria-label="Instagram"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
        <a
          href="https://linkedin.com"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-social__link"
          aria-label="LinkedIn"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
      </div>

      <div class="footer-right">
        <a href="/pbjwebsite/privacy/" class="footer-privacy">Privacy Policy</a>
        <p class="footer-copy">&copy; {year} PB&amp;J Agency. All rights reserved.</p>
      </div>
    </div>

  </div>

  <!-- Full-width brand statement — spans the entire bottom like Smith & Saint -->
  <div class="footer-wordmark" aria-hidden="true">MADE WITH PBJ</div>
</footer>

<style lang="scss">
  .site-footer {
    position: relative;
    z-index: 2;
    background: var(--plum-deep);
    padding: 64px 0 0;
    overflow: hidden;
    color: var(--white);
  }

  .site-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
    padding-bottom: 48px;
  }

  .footer-info {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 24px;

    @media (max-width: 768px) {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }

  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .footer-email {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--gold-light);
    letter-spacing: 0.5px;
    text-decoration: none;
    transition: opacity 200ms ease;

    &:hover { opacity: 0.75; }
  }

  .footer-location {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .footer-social {
    display: flex;
    align-items: center;
    gap: 20px;

    &__link {
      color: rgba(255, 255, 255, 0.4);
      transition: color 200ms ease;
      &:hover { color: var(--white); }
    }
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;

    @media (max-width: 768px) { align-items: flex-start; }
  }

  .footer-privacy {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.5px;
    text-decoration: none;
    transition: color 200ms ease;

    &:hover { color: rgba(255, 255, 255, 0.6); }
  }

  .footer-copy {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.5px;
    text-align: right;

    @media (max-width: 768px) { text-align: left; }
  }

  // Giant brand statement — bleeds edge to edge, clipped by overflow:hidden
  .footer-wordmark {
    display: block;
    width: 100%;
    text-align: center;
    font-family: var(--font-serif);
    font-size: clamp(40px, 11vw, 158px);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.05);
    white-space: nowrap;
    line-height: 0.82;
    letter-spacing: -2px;
    pointer-events: none;
    user-select: none;
  }
</style>
