---
---

<section id="hero" class="hero">
  <video
    class="hero__video"
    autoplay
    muted
    loop
    playsinline
    poster={`${import.meta.env.BASE_URL}/assets/hero-poster.jpg`}
    aria-hidden="true"
  >
    <source src={`${import.meta.env.BASE_URL}/assets/hero-reel.mp4`} type="video/mp4" />
  </video>
  <div class="hero__overlay" aria-hidden="true"></div>
</section>

<style lang="scss">
  .hero {
    position: fixed;
    inset: 0;
    z-index: 1;
    background: var(--burgundy-deep);
    overflow: hidden;
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.52);
    z-index: 1;
    pointer-events: none;
  }
</style>
