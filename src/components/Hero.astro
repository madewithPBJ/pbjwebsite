---
---

<section id="hero" class="hero">

  <!-- Cream background — revealed as card scales down -->
  <div class="hero__bg"></div>

  <!-- Video card: GSAP scales this down on scroll -->
  <div class="hero__card">
    <video
      class="hero__video"
      autoplay
      muted
      loop
      playsinline
      poster={`${import.meta.env.BASE_URL}/assets/hero-poster.jpg`}
      aria-hidden="true"
    >
      <source src={`${import.meta.env.BASE_URL}/assets/hero-reel.mp4`} type="video/mp4" />
    </video>
    <div class="hero__overlay" aria-hidden="true"></div>
  </div>

</section>

<style lang="scss">
  .hero {
    position: fixed;
    inset: 0;
    z-index: 1;
    overflow: hidden;
    background: var(--cream);
  }

  /* ─── Background ────────────────────────────── */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: var(--cream);
  }

  /* ─── Video card ────────────────────────────── */
  .hero__card {
    position: absolute;
    inset: 0;
    z-index: 1;
    transform-origin: center center;
    overflow: hidden;
    background: var(--burgundy-deep);
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.52);
    z-index: 1;
    pointer-events: none;
  }
</style>
