---
---

<section id="hero" class="hero">
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="hero__content">
    <img
      class="hero__logo js-logo-in"
      src={`${import.meta.env.BASE_URL}assets/PBJ-white.svg`}
      alt="PB&J Agency"
      width="280"
      height="auto"
    />
  </div>
</section>

<style lang="scss">
  .hero {
    position: relative;
    min-height: 100dvh;
    background: var(--burgundy-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    z-index: 1;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 50% 45%,
      rgba(61, 20, 84, 0.55) 0%,
      transparent 68%
    );
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .hero__logo {
    width: 280px;
    max-width: 70vw;

    @media (max-width: 480px) {
      width: 180px;
    }
  }
</style>
