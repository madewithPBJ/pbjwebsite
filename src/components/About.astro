---
---

<section id="about" class="about">
  <div class="about__inner wrap">
    <div class="about__content">
      <p class="eyebrow js-fade-up">Who We Are</p>

      <h2 class="about__headline js-fade-up">
        A different kind<br />of agency.
      </h2>

      <p class="about__body js-fade-up">
        PB&amp;J is a white-glove talent agency representing the world's most
        exceptional surgeons. We work with a small number of elite clients —
        connecting mastery with the institutions, platforms, and partnerships
        that deserve it.
      </p>

      <a href="#connect" class="btn btn-outline-dark js-fade-up">Learn More</a>
    </div>

    <div class="about__ghost" aria-hidden="true">
      <img src={`${import.meta.env.BASE_URL}assets/PBJ-nobkrd.svg`} alt="" />
    </div>
  </div>
</section>

<style lang="scss">
  .about {
    position: relative;
    z-index: 2;
    background: var(--cream);
    padding: 140px 0;

    @media (max-width: 768px) {
      padding: 80px 0;
    }
  }

  .about__inner {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
  }

  .about__content {
    max-width: 560px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 28px;
  }

  .about__headline {
    font-family: var(--font-serif);
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    line-height: 1.1;
    letter-spacing: -0.5px;
  }

  .about__body {
    font-family: var(--font-sans);
    font-size: var(--text-md);
    color: var(--ink-mid);
    line-height: 1.75;
    max-width: 480px;
  }

  .about__ghost {
    position: absolute;
    right: -20px;
    top: 50%;
    transform: translateY(-50%);
    width: 360px;
    opacity: 0.07;
    pointer-events: none;

    img {
      width: 100%;
    }

    @media (max-width: 900px) {
      display: none;
    }
  }
</style>
