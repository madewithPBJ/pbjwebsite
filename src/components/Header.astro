---
---

<header class="site-header">
  <div class="site-header__inner wrap">
    <span class="header-time" id="ny-time">DENVER, CO</span>

    <img
      class="header-logo-ref"
      src={`${import.meta.env.BASE_URL}/assets/PBJLOGO-NOBKGRDWHT.png`}
      alt=""
      aria-hidden="true"
      width="61"
    />

    <button class="header-menu-btn" id="menu-btn" aria-label="Open navigation">
      <span class="header-menu-btn__text">MENU</span>
      <span class="header-menu-btn__line" aria-hidden="true"></span>
    </button>
  </div>
</header>

<style lang="scss">
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 22px 0;
    color: var(--white);
    pointer-events: none;
  }

  .site-header__inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    pointer-events: auto;
  }

  .header-logo-ref {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 61px;
    height: auto;
    opacity: 0;
    pointer-events: none;
    display: block;
  }

  .header-time {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    transition: color 400ms ease;
  }

  .header-menu-btn {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    color: inherit;
    cursor: pointer;

    &__text {
      font-family: var(--font-sans);
      font-size: var(--text-xs);
      font-weight: 600;
      letter-spacing: 3px;
      text-transform: uppercase;
      line-height: 1;
    }

    &__line {
      display: block;
      width: 18px;
      height: 1px;
      background: currentColor;
      transition: width 200ms ease;
    }

    &:hover &__line {
      width: 24px;
    }
  }

  :global(.site-header--light) {
    color: var(--ink);

    .header-time {
      color: var(--muted);
    }
  }
</style>
