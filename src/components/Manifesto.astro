---
---

<section id="manifesto" class="manifesto">
  <div class="manifesto__inner wrap">
    <p class="eyebrow js-fade-up">Our Philosophy</p>

    <blockquote class="manifesto__quote js-fade-up">
      Where expertise<br />meets opportunity.
    </blockquote>

    <div class="manifesto__rule js-fade-up" aria-hidden="true"></div>

    <p class="manifesto__body js-fade-up">
      We represent the surgeons the world depends on — connecting mastery with
      the partnerships, platforms, and legacies that deserve it. Intentionally
      small. Impossibly selective.
    </p>
  </div>
</section>

<style lang="scss">
  .manifesto {
    position: relative;
    z-index: 2;
    background: var(--cream-dark);
    padding: 160px 0;
    text-align: center;

    @media (max-width: 768px) {
      padding: 100px 0;
    }
  }

  .manifesto__inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }

  .manifesto__quote {
    font-family: var(--font-serif);
    font-size: clamp(36px, 5.5vw, 60px);
    font-weight: 300;
    font-style: italic;
    color: var(--ink);
    line-height: 1.15;
    letter-spacing: -0.5px;

    @media (max-width: 600px) {
      br { display: none; }
    }
  }

  .manifesto__rule {
    width: 64px;
    height: 1.5px;
    background: var(--gold);
  }

  .manifesto__body {
    font-family: var(--font-sans);
    font-size: var(--text-md);
    color: var(--ink-mid);
    line-height: 1.75;
    max-width: 520px;
  }
</style>
