<section id="partners" class="partners">
  <div class="partners__inner wrap">
    <div class="partners__content">
      <p class="eyebrow js-fade-up">For Partners</p>

      <h2 class="partners__headline js-fade-up">
        Partners come to us<br />for more than reach.
      </h2>

      <p class="partners__body js-fade-up">
        Our clients deliver impact that extends far beyond the campaign —
        authenticity, precision, and credibility that only comes from the world's
        most respected surgeons.
      </p>

      <a href="#connect" class="btn btn-outline-dark js-fade-up">Learn More</a>
    </div>
  </div>
</section>

<style lang="scss">
  .partners {
    position: relative;
    z-index: 2;
    background: var(--cream);
    padding: 140px 0;

    @media (max-width: 768px) {
      padding: 80px 0;
    }
  }

  .partners__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: flex-end;
  }

  .partners__content {
    max-width: 560px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 28px;

    @media (max-width: 768px) {
      max-width: 100%;
    }
  }

  .partners__headline {
    font-family: var(--font-serif);
    font-size: clamp(36px, 4.5vw, 56px);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    line-height: 1.15;
    letter-spacing: -0.3px;

    @media (max-width: 600px) {
      br { display: none; }
    }
  }

  .partners__body {
    font-family: var(--font-sans);
    font-size: var(--text-md);
    color: var(--ink-mid);
    line-height: 1.75;
    max-width: 480px;
  }
</style>
